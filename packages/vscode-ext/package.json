{
  "name": "cph-ng",
  "displayName": "CPH-NG",
  "description": "The next generation of CPH.",
  "version": "0.7.6",
  "type": "module",
  "license": "AGPL-3.0-only",
  "publisher": "langningchen",
  "icon": "res/cph-ng.png",
  "galleryBanner": {
    "color": "#8adbae",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/langningchen/cph-ng/issues",
    "email": "i@langningchen.com"
  },
  "qna": "https://github.com/langningchen/cph-ng/discussions/categories/q-a",
  "pricing": "Free",
  "l10n": "./l10n",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/langningchen/cph-ng"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "exports": "./dist/extension.js",
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "problem.cph-ng.json",
        "url": "./dist/problem.schema.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "cph-ng_run_test_cases",
        "toolReferenceName": "cphNgRunTestcases",
        "displayName": "Run CPH-NG Test Cases",
        "modelDescription": "Executes test cases for the active competitive programming problem. Returns a JSON summary of verdicts, time, and memory usage for each executed case. Use this to quickly validate the current solution or specific test IDs.",
        "userDescription": "Runs one or all test cases for the current problem.",
        "canBeReferencedInPrompt": true,
        "icon": "$(play)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "testcaseId": {
              "type": "string",
              "description": "Optional test case ID (UUID) to run. Omit to execute the full suite."
            },
            "activePath": {
              "type": "string",
              "description": "Optional file path. Defaults to the currently active editor if omitted."
            }
          }
        }
      },
      {
        "name": "cph-ng_inspect_test_case",
        "toolReferenceName": "cphNgInspectTestCase",
        "displayName": "Inspect CPH-NG Test Case Details",
        "modelDescription": "Retrieves detailed diagnostic data for a specific test case (by UUID). Use 'all' to get a complete snapshot (stdin, expected, actual stdout, stderr, and meta) in one call, which is highly recommended for debugging failures to save context turns.",
        "userDescription": "Reads full details or a specific field (stdin/stdout/etc.) for a test case.",
        "canBeReferencedInPrompt": true,
        "icon": "$(file)",
        "inputSchema": {
          "type": "object",
          "required": [
            "testcaseId"
          ],
          "properties": {
            "dataType": {
              "type": "string",
              "enum": [
                "all",
                "stdin",
                "answer",
                "stdout",
                "stderr",
                "meta"
              ],
              "default": "all",
              "description": "Data slice to fetch. 'all' provides the complete context including I/O and performance stats."
            },
            "testcaseId": {
              "type": "string",
              "description": "The stable UUID of the test case."
            },
            "activePath": {
              "type": "string",
              "description": "Optional file path. Defaults to the currently active editor if omitted."
            }
          }
        }
      },
      {
        "name": "cph-ng_get_problem_context",
        "toolReferenceName": "cphNgGetProblemContext",
        "displayName": "Get CPH-NG Problem Context",
        "modelDescription": "Consolidated tool to fetch problem metadata (name, URL, time/memory limits) and a full list of test cases with their status and IDs. Use this once at the start of a session or after major changes to understand the problem constraints and available test points.",
        "userDescription": "Fetches problem limits and all test case IDs/statuses.",
        "canBeReferencedInPrompt": true,
        "icon": "$(info)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "activePath": {
              "type": "string",
              "description": "Optional file path. Defaults to the currently active editor if omitted."
            }
          }
        }
      },
      {
        "name": "cph-ng_upsert_test_case",
        "toolReferenceName": "cphNgUpsertTestcase",
        "displayName": "Add/Update CPH-NG Test Case",
        "modelDescription": "Creates a new test case or updates an existing one. Accepts inline stdin/answer content and can toggle a test's enabled status. Automatically clears previous results to allow re-running. Use this to persist edge cases or correct expected outputs.",
        "userDescription": "Adds or updates test case content (stdin/answer) for the current problem.",
        "canBeReferencedInPrompt": true,
        "icon": "$(edit)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "testcaseId": {
              "type": "string",
              "description": "Optional test case ID (UUID) to update. Omit to create a new case."
            },
            "stdin": {
              "type": "string",
              "description": "Standard input content."
            },
            "answer": {
              "type": "string",
              "description": "Expected output content."
            },
            "isDisabled": {
              "type": "boolean",
              "description": "Set testing status of this case."
            },
            "activePath": {
              "type": "string",
              "description": "Optional file path. Defaults to the currently active editor if omitted."
            }
          }
        }
      }
    ],
    "languageModelPrompts": [
      {
        "id": "cph-ng.analyzeFailure",
        "name": "CPH-NG: Analyze failing test",
        "description": "Diagnose a failing competitive programming attempt by running the managed test cases, inspecting the failing data, and outlining next steps.",
        "prompt": "You are assisting with a competitive programming workspace managed by CPH-NG.\n- Call `cph-ng_get_problem_context` once to understand the problem limits and test case IDs.\n- Run the tests via `cph-ng_run_test_cases`. It returns a summary of which IDs failed.\n- For failing IDs, call `cph-ng_inspect_test_case` with `dataType: 'all'` to get full diagnostic data in one turn.\n- Summarize root causes and suggest code fixes based on the observed differences.\n\nUser request:\n{{input}}"
      },
      {
        "id": "cph-ng.designEdgeCases",
        "name": "CPH-NG: Generate edge tests",
        "description": "Brainstorm tricky inputs for the active problem and persist them as executable CPH-NG test cases.",
        "prompt": "You are helping design stress tests for a competitive programming solution managed by CPH-NG.\n- Call `cph-ng_get_problem_context` to understand current coverage.\n- Brainstorm scenarios (e.g., max constraints, empty inputs, precision limits).\n- Save them with `cph-ng_upsert_test_case` (omit `id` for new cases).\n- Recommend running them via `cph-ng_run_test_cases` to verify compliance.\n\nUser request:\n{{input}}"
      }
    ],
    "views": {
      "cphNgContainer": [
        {
          "id": "cphNgSidebar",
          "name": "%views.cphNgContainer.name%",
          "type": "webview",
          "icon": "./res/panel-view-icon.svg"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cphNgContainer",
          "title": "%viewsContainers.activitybar%",
          "icon": "./res/panel-view-icon.svg"
        }
      ]
    },
    "configuration": [
      {
        "id": "basic",
        "order": 0,
        "title": "%config.basic%",
        "properties": {
          "cph-ng.basic.folderOpener": {
            "type": "string",
            "default": "tree",
            "enum": [
              "tree",
              "flat"
            ],
            "markdownDescription": "%config.basic.folderOpener%",
            "markdownEnumDescriptions": [
              "%config.basic.folderOpener.tree%",
              "%config.basic.folderOpener.flat%"
            ]
          },
          "cph-ng.basic.showPanel": {
            "type": "number",
            "default": -1,
            "markdownDescription": "%config.basic.showPanel%",
            "enum": [
              -1,
              -2,
              1,
              2,
              3,
              4,
              5,
              6,
              7,
              8,
              9
            ],
            "enumItemLabels": [
              "%config.basic.showPanel.-1%",
              "%config.basic.showPanel.-2%",
              "%config.basic.showPanel.1%",
              "%config.basic.showPanel.2%",
              "%config.basic.showPanel.3%",
              "%config.basic.showPanel.4%",
              "%config.basic.showPanel.5%",
              "%config.basic.showPanel.6%",
              "%config.basic.showPanel.7%",
              "%config.basic.showPanel.8%",
              "%config.basic.showPanel.9%"
            ]
          }
        }
      },
      {
        "id": "languages",
        "order": 1,
        "title": "%config.languages%",
        "properties": {
          "cph-ng.languages.cCompiler": {
            "type": "string",
            "default": "gcc",
            "markdownDescription": "%config.languages.cCompiler%"
          },
          "cph-ng.languages.cCompilerArgs": {
            "type": "string",
            "default": "-O2 -std=c11 -Wall -DCPH",
            "markdownDescription": "%config.languages.cCompilerArgs%"
          },
          "cph-ng.languages.cppCompiler": {
            "type": "string",
            "default": "g++",
            "markdownDescription": "%config.languages.cppCompiler%"
          },
          "cph-ng.languages.cppCompilerArgs": {
            "type": "string",
            "default": "-O2 -std=c++14 -Wall -DCPH",
            "markdownDescription": "%config.languages.cppCompilerArgs%"
          },
          "cph-ng.languages.cppObjcopy": {
            "type": "string",
            "default": "objcopy",
            "markdownDescription": "%config.languages.cppObjcopy%"
          },
          "cph-ng.languages.rustCompiler": {
            "type": "string",
            "default": "rustc",
            "markdownDescription": "%config.languages.rustCompiler%"
          },
          "cph-ng.languages.rustCompilerArgs": {
            "type": "string",
            "default": "-C opt-level=2",
            "markdownDescription": "%config.languages.rustCompilerArgs%"
          },
          "cph-ng.languages.javaCompiler": {
            "type": "string",
            "default": "javac",
            "markdownDescription": "%config.languages.javaCompiler%"
          },
          "cph-ng.languages.javaCompilerArgs": {
            "type": "string",
            "default": "-cp .",
            "markdownDescription": "%config.languages.javaCompilerArgs%"
          },
          "cph-ng.languages.javaRunner": {
            "type": "string",
            "default": "java",
            "markdownDescription": "%config.languages.javaRunner%"
          },
          "cph-ng.languages.javaRunnerArgs": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.languages.javaRunnerArgs%"
          },
          "cph-ng.languages.pythonCompiler": {
            "type": "string",
            "default": "pypy3",
            "markdownDescription": "%config.languages.pythonCompiler%"
          },
          "cph-ng.languages.pythonCompilerArgs": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.languages.pythonCompilerArgs%"
          },
          "cph-ng.languages.pythonRunner": {
            "type": "string",
            "default": "pypy3",
            "markdownDescription": "%config.languages.pythonRunner%"
          },
          "cph-ng.languages.pythonRunnerArgs": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.languages.pythonRunnerArgs%"
          },
          "cph-ng.languages.javascriptRunner": {
            "type": "string",
            "default": "node",
            "markdownDescription": "%config.languages.javascriptRunner%"
          },
          "cph-ng.languages.javascriptRunnerArgs": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.languages.javascriptRunnerArgs%"
          }
        }
      },
      {
        "id": "run",
        "order": 2,
        "title": "%config.run%",
        "properties": {
          "cph-ng.run.compilationTimeout": {
            "type": "number",
            "default": 10000,
            "markdownDescription": "%config.run.compilationTimeout%"
          },
          "cph-ng.run.useWrapper": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.run.useWrapper%"
          },
          "cph-ng.run.useHook": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.run.useHook%"
          },
          "cph-ng.run.useRunner": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.run.useRunner%"
          },
          "cph-ng.run.timeAddition": {
            "type": "number",
            "default": 1000,
            "markdownDescription": "%config.run.timeAddition%"
          },
          "cph-ng.run.unlimitedStack": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.run.unlimitedStack%"
          }
        }
      },
      {
        "id": "comparing",
        "order": 3,
        "title": "%config.comparing%",
        "properties": {
          "cph-ng.comparing.oleSize": {
            "type": "number",
            "default": 8,
            "markdownDescription": "%config.comparing.oleSize%"
          },
          "cph-ng.comparing.regardPEAsAC": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.comparing.regardPEAsAC%"
          },
          "cph-ng.comparing.ignoreError": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%config.comparing.ignoreError%"
          }
        }
      },
      {
        "id": "stressTest",
        "order": 4,
        "title": "%config.stressTest%",
        "properties": {
          "cph-ng.stressTest.generatorTimeLimit": {
            "type": "number",
            "default": 10000,
            "markdownDescription": "%config.stressTest.generatorTimeLimit%"
          },
          "cph-ng.stressTest.bruteForceTimeLimit": {
            "type": "number",
            "default": 60000,
            "markdownDescription": "%config.stressTest.bruteForceTimeLimit%"
          }
        }
      },
      {
        "id": "problem",
        "order": 5,
        "title": "%config.problem%",
        "properties": {
          "cph-ng.problem.defaultTimeLimit": {
            "type": "number",
            "default": 1000,
            "markdownDescription": "%config.problem.defaultTimeLimit%"
          },
          "cph-ng.problem.defaultMemoryLimit": {
            "type": "number",
            "default": 512,
            "markdownDescription": "%config.problem.defaultMemoryLimit%"
          },
          "cph-ng.problem.foundMatchTestcaseBehavior": {
            "type": "string",
            "default": "always",
            "enum": [
              "ask",
              "always",
              "never"
            ],
            "markdownDescription": "%config.problem.foundMatchTestcaseBehavior%",
            "markdownEnumDescriptions": [
              "%config.problem.foundMatchTestcaseBehavior.ask%",
              "%config.problem.foundMatchTestcaseBehavior.always%",
              "%config.problem.foundMatchTestcaseBehavior.never%"
            ]
          },
          "cph-ng.problem.expandBehavior": {
            "type": "string",
            "default": "firstFailed",
            "enum": [
              "always",
              "never",
              "failed",
              "first",
              "firstFailed",
              "same"
            ],
            "markdownDescription": "%config.problem.expandBehavior%",
            "markdownEnumDescriptions": [
              "%config.problem.expandBehavior.always%",
              "%config.problem.expandBehavior.never%",
              "%config.problem.expandBehavior.failed%",
              "%config.problem.expandBehavior.first%",
              "%config.problem.expandBehavior.firstFailed%",
              "%config.problem.expandBehavior.same%"
            ]
          },
          "cph-ng.problem.templateFile": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.problem.templateFile%"
          },
          "cph-ng.problem.problemFilePath": {
            "type": "string",
            "default": "${workspace}/.cph-ng/${relativeDirname}/${basename}.bin",
            "markdownDescription": "%config.problem.problemFilePath%"
          },
          "cph-ng.problem.testcaseFilePath": {
            "type": "string",
            "default": "${workspace}/.cph-ng/${relativeDirname}/${basename}.${id}.${ext}",
            "markdownDescription": "%config.problem.testcaseFilePath%"
          },
          "cph-ng.problem.unzipFolder": {
            "type": "string",
            "default": "${workspace}/.cph-ng/${zipBasenameNoExt}",
            "markdownDescription": "%config.problem.unzipFolder%"
          },
          "cph-ng.problem.deleteAfterUnzip": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.problem.deleteAfterUnzip%"
          },
          "cph-ng.problem.clearBeforeLoad": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.problem.clearBeforeLoad%"
          },
          "cph-ng.problem.maxInlineDataLength": {
            "type": "number",
            "default": 65536,
            "markdownDescription": "%config.problem.maxInlineDataLength%"
          },
          "cph-ng.problem.inputFileExtensionList": {
            "type": "array",
            "default": [
              ".in"
            ],
            "items": {
              "type": "string"
            },
            "markdownDescription": "%config.problem.inputFileExtensionList%"
          },
          "cph-ng.problem.outputFileExtensionList": {
            "type": "array",
            "default": [
              ".ans",
              ".out"
            ],
            "items": {
              "type": "string"
            },
            "markdownDescription": "%config.problem.outputFileExtensionList%"
          }
        }
      },
      {
        "id": "cache",
        "order": 6,
        "title": "%config.cache%",
        "properties": {
          "cph-ng.cache.directory": {
            "type": "string",
            "default": "${tmp}/cph-ng",
            "markdownDescription": "%config.cache.directory%"
          },
          "cph-ng.cache.cleanOnStartup": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%config.cache.cleanOnStartup%"
          }
        }
      },
      {
        "id": "cphCapable",
        "order": 7,
        "title": "%config.cphCapable%",
        "properties": {
          "cph-ng.cphCapable.enabled": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%config.cphCapable.enabled%"
          }
        }
      },
      {
        "id": "companion",
        "order": 8,
        "title": "%config.companion%",
        "properties": {
          "cph-ng.companion.listenPort": {
            "type": "number",
            "scope": "machine",
            "default": 27121,
            "markdownDescription": "%config.companion.listenPort%"
          },
          "cph-ng.companion.logFile": {
            "type": "string",
            "default": "${home}/.cph-ng-router.log",
            "markdownDescription": "%config.companion.logFile%"
          },
          "cph-ng.companion.confirmSubmit": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%config.companion.confirmSubmit%"
          },
          "cph-ng.companion.shutdownTimeout": {
            "type": "number",
            "default": 10000,
            "minimum": 1,
            "markdownDescription": "%config.companion.shutdownTimeout%"
          },
          "cph-ng.companion.customPathScript": {
            "type": "string",
            "default": "${extensionPath}/res/defaultScript.js",
            "markdownDescription": "%config.companion.customPathScript%"
          }
        }
      },
      {
        "id": "sidebar",
        "order": 9,
        "title": "%config.sidebar%",
        "properties": {
          "cph-ng.sidebar.retainWhenHidden": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%config.sidebar.retainWhenHidden%"
          },
          "cph-ng.sidebar.showAcGif": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%config.sidebar.showAcGif%"
          },
          "cph-ng.sidebar.hiddenStatuses": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "UKE",
                "AC",
                "PC",
                "PE",
                "WA",
                "TLE",
                "MLE",
                "OLE",
                "RE",
                "RF",
                "CE",
                "SE",
                "WT",
                "FC",
                "CP",
                "CPD",
                "JG",
                "JGD",
                "CMP",
                "SK",
                "RJ"
              ],
              "enumDescriptions": [
                "%config.sidebar.hiddenStatuses.UKE%",
                "%config.sidebar.hiddenStatuses.AC%",
                "%config.sidebar.hiddenStatuses.PC%",
                "%config.sidebar.hiddenStatuses.PE%",
                "%config.sidebar.hiddenStatuses.WA%",
                "%config.sidebar.hiddenStatuses.TLE%",
                "%config.sidebar.hiddenStatuses.MLE%",
                "%config.sidebar.hiddenStatuses.OLE%",
                "%config.sidebar.hiddenStatuses.RE%",
                "%config.sidebar.hiddenStatuses.RF%",
                "%config.sidebar.hiddenStatuses.CE%",
                "%config.sidebar.hiddenStatuses.SE%",
                "%config.sidebar.hiddenStatuses.WT%",
                "%config.sidebar.hiddenStatuses.FC%",
                "%config.sidebar.hiddenStatuses.CP%",
                "%config.sidebar.hiddenStatuses.CPD%",
                "%config.sidebar.hiddenStatuses.JG%",
                "%config.sidebar.hiddenStatuses.JGD%",
                "%config.sidebar.hiddenStatuses.CMP%",
                "%config.sidebar.hiddenStatuses.SK%",
                "%config.sidebar.hiddenStatuses.RJ%"
              ]
            },
            "uniqueItems": true,
            "default": [],
            "markdownDescription": "%config.sidebar.hiddenStatuses%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "cph-ng.versionInfo",
        "title": "CPH-NG: Version Info"
      },
      {
        "command": "cph-ng.importFromCph",
        "title": "%commands.importFromCph%"
      },
      {
        "command": "cph-ng.createProblem",
        "title": "%commands.createProblem%",
        "icon": "$(rocket)"
      },
      {
        "command": "cph-ng.importProblem",
        "title": "%commands.importProblem%",
        "icon": "$(desktop-download)"
      },
      {
        "command": "cph-ng.runAllTestcases",
        "title": "%commands.runTestcases%",
        "icon": "$(run-all)"
      },
      {
        "command": "cph-ng.stopTestcases",
        "title": "%commands.stopTestcases%",
        "icon": "$(stop-circle)"
      },
      {
        "command": "cph-ng.submit",
        "title": "%commands.submit%"
      }
    ],
    "keybindings": [
      {
        "command": "cph-ng.createProblem",
        "key": "ctrl+alt+b",
        "when": "!cph-ng.hasProblem && !cph-ng.canImport"
      },
      {
        "command": "cph-ng.importProblem",
        "key": "ctrl+alt+b",
        "when": "!cph-ng.hasProblem && cph-ng.canImport"
      },
      {
        "command": "cph-ng.runAllTestcases",
        "key": "ctrl+alt+b",
        "when": "cph-ng.hasProblem && !cph-ng.isRunning"
      },
      {
        "command": "cph-ng.stopTestcases",
        "key": "ctrl+alt+b",
        "when": "cph-ng.hasProblem && cph-ng.isRunning"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cph-ng.createProblem",
          "when": "!cph-ng.hasProblem",
          "group": "navigation"
        },
        {
          "command": "cph-ng.runAllTestcases",
          "when": "cph-ng.hasProblem && !cph-ng.isRunning",
          "group": "navigation"
        },
        {
          "command": "cph-ng.stopTestcases",
          "when": "cph-ng.hasProblem && cph-ng.isRunning",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "webpack --disable-interpret --mode production",
    "watch": "webpack --disable-interpret --watch --mode development",
    "clean": "rimraf dist out scripts/out *.vsix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui --coverage",
    "check-translations": "tsx --tsconfig scripts/tsconfig.json scripts/check-translations.ts",
    "generate-settings": "tsx scripts/generate-settings.ts",
    "package": "tsx scripts/package.ts",
    "postinstall": "pnpm generate-settings"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/adm-zip": "^0.5.8",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "~22.19.7",
