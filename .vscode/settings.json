{
  "files.exclude": {
    "dist": false
  },
  "search.exclude": {
    "dist": true
  },
  "js/ts.tsc.autoDetect": "off",
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
    "^@mui/[^/]+$",
    "^@mui/[^/]+/esm$",
    "^@mui/[^/]+/esm/[^/]+$"
  ],
  "cSpell.words": [
    "atcoder",
    "Cascadia",
    "chrono",
    "codeeditors",
    "Codeforces",
    "commitlint",
    "Consolas",
    "CPHNG",
    "DCPH",
    "divyanshuagrawal",
    "interactor",
    "javac",
    "Kattis",
    "lezer",
    "Luogu",
    "Monaspace",
    "msys",
    "objcopy",
    "partysocket",
    "problemset",
    "Promisable",
    "testlib",
    "tsyringe",
    "ucrtbase",
    "winlibs"
  ],
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "docthis.includeTypes": false,
  "docthis.includeMemberOfOnClassMembers": false,
  "docthis.includeMemberOfOnInterfaceMembers": false,
  "emmet.showAbbreviationSuggestions": false,
  "emmet.showExpandedAbbreviation": "never"
}
