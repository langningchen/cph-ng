{
  "js/ts.tsc.autoDetect": "off",
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
    "^@mui/[^/]+$",
    "^@mui/[^/]+/esm$",
    "^@mui/[^/]+/esm/[^/]+$"
  ],
  "cSpell.words": [
    "atcoder",
    "Cascadia",
    "chrono",
    "codeeditors",
    "Codeforces",
    "commitlint",
    "Consolas",
    "CPHNG",
    "DCPH",
    "divyanshuagrawal",
    "endgroup",
    "interactor",
    "javac",
    "Kattis",
    "lezer",
    "Luogu",
    "Monaspace",
    "msys",
    "nothrow",
    "objcopy",
    "onnx",
    "onnxruntime",
    "partysocket",
    "problemset",
    "Promisable",
    "testlib",
    "tsyringe",
    "ucrtbase",
    "webext",
    "winlibs"
  ],
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "docthis.includeTypes": false,
  "docthis.includeMemberOfOnClassMembers": false,
  "docthis.includeMemberOfOnInterfaceMembers": false,
  "emmet.showAbbreviationSuggestions": false,
  "emmet.showExpandedAbbreviation": "never",
  "explorer.excludeGitIgnore": true,
  "editor.defaultFormatter": "biomejs.biome",
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
